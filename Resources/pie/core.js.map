
        export const sep       = "/";
        export const join      = (...p) => p.filter(Boolean).join("/").replace(/\/+/g, "/");
        export const dirname   = (p) => p.split("/").slice(0, -1).join("/") || "/";
        export const basename  = (p, ext) => { const b = p.split("/").pop() || ""; return ext && b.endsWith(ext) ? b.slice(0, -ext.length) : b; };
        export const extname   = (p) => { const b = p.split("/").pop() || ""; const i = b.lastIndexOf("."); return i > 0 ? b.slice(i) : ""; };
        export const resolve   = (...p) => p.join("/");
        export const normalize = (p) => p.replace(/\/+/g, "/");
        export const isAbsolute = (p) => p.startsWith("/");
        export const relative  = (from, to) => to;
        export default { sep, join, dirname, basename, extname, resolve, normalize, isAbsolute, relative };
      